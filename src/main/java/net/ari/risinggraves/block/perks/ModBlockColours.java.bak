package net.ari.risinggraves.block.perks;

import net.minecraft.client.Minecraft;
import net.minecraft.client.color.block.BlockColor;
import net.minecraft.client.color.block.BlockColors;
import net.minecraftforge.api.distmarker.Dist;
import net.minecraftforge.client.event.RegisterColorHandlersEvent;
import net.minecraftforge.eventbus.api.SubscribeEvent;
import net.minecraftforge.fml.common.Mod;
import net.ari.risinggraves.block.ModBlocks;
import net.ari.risinggraves.block.PerkMachineBlockEntity;

@Mod.EventBusSubscriber(value = Dist.CLIENT, bus = Mod.EventBusSubscriber.Bus.MOD)
public class ModBlockColours {


    @SubscribeEvent
        public static void registerBlockColors(RegisterColorHandlersEvent.Block event) {

            BlockColor perkMachineColor = (state, level, pos, tintIndex) -> {
                System.out.println("[TINT] CALLED");
                System.out.println("[TINT] level=" + level);
                System.out.println("[TINT] pos=" + pos);

                var clientLevel = Minecraft.getInstance().level;
                var be = clientLevel != null && pos != null ? clientLevel.getBlockEntity(pos) : null;

                System.out.println("[TINT] BE=" + be);

                if (be instanceof PerkMachineBlockEntity machine) {
                    System.out.println("[TINT] MACHINE FOUND, PERK=" + machine.getPerk());
                    return machine.getColor();
                }

                System.out.println("[TINT] FALLBACK");
                return 0xFFFFFF;
            };





        event.register(perkMachineColor, ModBlocks.PERK_MACHINE.get());
    }
}

